{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "title": "Toy Board — Overview",
  "uid": "toy-board-overview",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "5s",
  "time": {"from": "now-15m", "to": "now"},
  "tags": ["toy-board", "spring-boot"],
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s) by URI",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"toy-board\"}[1m]))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latency p95 (s) by URI",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{application=\"toy-board\"}[1m])))",
          "legendFormat": "p95 {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (all requests)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"toy-board\"}[1m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"toy-board\"}[1m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"toy-board\"}[1m])))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP errors (4xx / 5xx) req/s",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (status) (rate(http_server_requests_seconds_count{application=\"toy-board\",status=~\"4..|5..\"}[1m]))", "legendFormat": "{{status}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM heap used",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (area) (jvm_memory_used_bytes{application=\"toy-board\"})", "legendFormat": "{{area}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "GC pause (s, rate)",
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (action, cause) (rate(jvm_gc_pause_seconds_sum{application=\"toy-board\"}[1m]))", "legendFormat": "{{action}} / {{cause}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HikariCP connections (active / idle / pending)",
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "hikaricp_connections_active{application=\"toy-board\"}", "legendFormat": "active", "refId": "A"},
        {"expr": "hikaricp_connections_idle{application=\"toy-board\"}", "legendFormat": "idle", "refId": "B"},
        {"expr": "hikaricp_connections_pending{application=\"toy-board\"}", "legendFormat": "pending", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Process CPU",
      "gridPos": {"x": 0, "y": 23, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "process_cpu_usage{application=\"toy-board\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 2}, "overrides": []}
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Live threads",
      "gridPos": {"x": 6, "y": 23, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "jvm_threads_live_threads{application=\"toy-board\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Uptime",
      "gridPos": {"x": 12, "y": 23, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "process_uptime_seconds{application=\"toy-board\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Total requests (/s)",
      "gridPos": {"x": 18, "y": 23, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{application=\"toy-board\"}[1m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 1}, "overrides": []}
    }
  ]
}
