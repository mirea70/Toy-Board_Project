{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "title": "Toy Board — Overview",
  "uid": "toy-board-overview",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "5s",
  "time": {"from": "now-15m", "to": "now"},
  "tags": ["toy-board", "spring-boot"],
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s) by method + URI",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (method, uri) (rate(http_server_requests_seconds_count{application=\"toy-board\",uri!~\"/actuator/.*\"}[1m]))",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latency p95 (s) by method + URI",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, method, uri) (rate(http_server_requests_seconds_bucket{application=\"toy-board\",uri!~\"/actuator/.*\"}[1m])))",
          "legendFormat": "p95 {{method}} {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (all requests)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"toy-board\"}[1m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"toy-board\"}[1m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"toy-board\"}[1m])))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP errors (4xx / 5xx) req/s",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (status) (rate(http_server_requests_seconds_count{application=\"toy-board\",status=~\"4..|5..\"}[1m]))", "legendFormat": "{{status}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM heap used",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (area) (jvm_memory_used_bytes{application=\"toy-board\"})", "legendFormat": "{{area}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "JVM total memory vs Container limit",
      "gridPos": {"x": 0, "y": 23, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(jvm_memory_used_bytes{application=\"toy-board\",area=\"heap\"})", "legendFormat": "heap used", "refId": "A"},
        {"expr": "sum(jvm_memory_used_bytes{application=\"toy-board\",area=\"nonheap\"})", "legendFormat": "nonheap used", "refId": "B"},
        {"expr": "sum(jvm_memory_used_bytes{application=\"toy-board\"})", "legendFormat": "total used (heap+nonheap)", "refId": "C"},
        {"expr": "sum(jvm_memory_committed_bytes{application=\"toy-board\"})", "legendFormat": "total committed", "refId": "D"},
        {"expr": "vector(536870912)", "legendFormat": "container limit (512MB)", "refId": "E"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "container limit (512MB)"}, "properties": [{"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10,10]}}, {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "total committed"}, "properties": [{"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [5,5]}}, {"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "total used (heap+nonheap)"}, "properties": [{"id": "custom.lineWidth", "value": 2}, {"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "GC pause (s, rate)",
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (action, cause) (rate(jvm_gc_pause_seconds_sum{application=\"toy-board\"}[1m]))", "legendFormat": "{{action}} / {{cause}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HikariCP connections (active / idle / pending)",
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "hikaricp_connections_active{application=\"toy-board\"}", "legendFormat": "active", "refId": "A"},
        {"expr": "hikaricp_connections_idle{application=\"toy-board\"}", "legendFormat": "idle", "refId": "B"},
        {"expr": "hikaricp_connections_pending{application=\"toy-board\"}", "legendFormat": "pending", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Live threads",
      "gridPos": {"x": 12, "y": 30, "w": 4, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "jvm_threads_live_threads{application=\"toy-board\"}", "legendFormat": "{{service}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name", "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "horizontal"}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Uptime",
      "gridPos": {"x": 16, "y": 30, "w": 4, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "process_uptime_seconds{application=\"toy-board\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Total requests (/s)",
      "gridPos": {"x": 20, "y": 30, "w": 4, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{application=\"toy-board\"}[1m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 1}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value", "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "horizontal"}
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Server time share by method + URI (s/s) — CPU 점유 비중",
      "description": "method + URI 조합별로 서버가 초당 몇 초를 처리에 썼는지. 총합이 container CPU 수 (예: 2.0) 에 가까울수록 포화. 값이 높은 엔드포인트가 CPU 의 대부분을 먹는 병목.",
      "gridPos": {"x": 0, "y": 37, "w": 12, "h": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (method, uri) (rate(http_server_requests_seconds_sum{application=\"toy-board\",uri!~\"/actuator/.*\"}[1m]))",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "stacking": {"mode": "normal", "group": "A"},
            "fillOpacity": 30,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Kafka Consumer Lag (records)",
      "description": "Kafka consumer lag per consumer group / topic / partition (records behind).",
      "gridPos": {"x": 0, "y": 46, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag_max",
          "legendFormat": "{{client_id}} {{topic}}-{{partition}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Spring CPU Usage by Instance",
      "description": "process_cpu_usage per Spring instance (write-app vs read-app). 0~1 scale (0% ~ 100%).",
      "gridPos": {"x": 12, "y": 46, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"toy-board\"}",
          "legendFormat": "{{service}} ({{instance}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 2, "min": 0, "max": 1}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 18,
      "type": "table",
      "title": "Endpoint 처리 효율 — 요청 수 / 누적 처리 시간 / 요청당 평균 (time range 누적)",
      "description": "각 method + URI 의 누적 요청 수, 누적 wall-clock 처리 시간, 두 값의 나눗셈으로 구한 요청당 평균. 고볼륨 엔드포인트와 per-request 고비용 엔드포인트를 한 표에서 구분 가능.",
      "gridPos": {"x": 0, "y": 54, "w": 24, "h": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (method, uri) (increase(http_server_requests_seconds_count{application=\"toy-board\",uri!~\"/actuator/.*\"}[$__range]))",
          "refId": "A",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        },
        {
          "expr": "sum by (method, uri) (increase(http_server_requests_seconds_sum{application=\"toy-board\",uri!~\"/actuator/.*\"}[$__range]))",
          "refId": "B",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        },
        {
          "expr": "sum by (method, uri) (increase(http_server_requests_seconds_sum{application=\"toy-board\",uri!~\"/actuator/.*\"}[$__range])) / sum by (method, uri) (increase(http_server_requests_seconds_count{application=\"toy-board\",uri!~\"/actuator/.*\"}[$__range]))",
          "refId": "C",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        }
      ],
      "transformations": [
        {"id": "merge", "options": {}},
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "renameByName": {
              "method": "Method",
              "uri": "URI",
              "Value #A": "요청 수",
              "Value #B": "누적 처리 시간",
              "Value #C": "요청당 평균"
            },
            "indexByName": {
              "Method": 0,
              "URI": 1,
              "Value #A": 2,
              "Value #B": 3,
              "Value #C": 4
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}, "inspect": false},
          "mappings": [],
          "color": {"mode": "continuous-GrYlRd"},
          "fieldMinMax": true,
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "요청 수"},
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "decimals", "value": 0},
              {"id": "custom.cellOptions", "value": {"type": "gauge", "mode": "gradient"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "누적 처리 시간"},
            "properties": [
              {"id": "unit", "value": "s"},
              {"id": "decimals", "value": 2},
              {"id": "custom.cellOptions", "value": {"type": "gauge", "mode": "gradient"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "요청당 평균"},
            "properties": [
              {"id": "unit", "value": "s"},
              {"id": "decimals", "value": 4},
              {"id": "custom.cellOptions", "value": {"type": "gauge", "mode": "gradient"}}
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {"show": false, "reducer": ["sum"], "countRows": false, "fields": ""},
        "sortBy": [{"desc": true, "displayName": "누적 처리 시간"}]
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Tomcat Thread Pool — busy vs max (thread pool 포화 감지)",
      "description": "busy 가 max (기본 200) 에 수렴하면 요청이 Tomcat acceptor 대기열로 밀려 latency 폭증. max 는 대시선(--). 단 metric 노출엔 spring.jmx.enabled=true 필요.",
      "gridPos": {"x": 0, "y": 66, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "tomcat_threads_busy_threads{application=\"toy-board\"}",
          "legendFormat": "busy — {{service}} ({{instance}})",
          "refId": "A"
        },
        {
          "expr": "tomcat_threads_config_max_threads{application=\"toy-board\"}",
          "legendFormat": "max — {{service}} ({{instance}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "min": 0},
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": "^max.*"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
              {"id": "custom.lineWidth", "value": 1}
            ]
          }
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "JVM Thread States by instance (I/O wait 확인)",
      "description": "RUNNABLE 은 실제 CPU 작업. WAITING / TIMED_WAITING / BLOCKED 급증 구간은 외부 I/O 대기 (Redis connection / HTTP client pool / lock). CPU 가 낮은데 이 상태 수치가 높으면 thread 가 놀고 있는 게 아니라 외부 자원 대기 중.",
      "gridPos": {"x": 12, "y": 66, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "jvm_threads_states_threads{application=\"toy-board\",state=~\"waiting|timed-waiting|blocked|runnable\"}",
          "legendFormat": "{{state}} — {{service}} ({{instance}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "min": 0, "custom": {"fillOpacity": 20}},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Prometheus Scrape Health — up (1/0) + scrape_duration_seconds",
      "description": "up=0 구간은 Prometheus 가 target 을 scrape 실패한 시점 (target 이 scrape 엔드포인트 응답 못할 만큼 포화). scrape_duration_seconds 가 timeout (기본 10s) 근처로 튀면 scrape 지연 — 이게 heap/CPU 그래프의 결측/거짓 drop 의 원인.",
      "gridPos": {"x": 0, "y": 74, "w": 24, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "up{job=~\"toy-board-.*\"}",
          "legendFormat": "up — {{job}} ({{instance}})",
          "refId": "A"
        },
        {
          "expr": "scrape_duration_seconds{job=~\"toy-board-.*\"}",
          "legendFormat": "duration(s) — {{job}} ({{instance}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 3, "min": 0},
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": "^up.*"},
            "properties": [
              {"id": "custom.drawStyle", "value": "bars"},
              {"id": "custom.fillOpacity", "value": 30},
              {"id": "max", "value": 1.2}
            ]
          }
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "min", "max", "lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    }
  ]
}
